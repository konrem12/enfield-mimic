# MIMIC-IV Race Categorization
def classify_race(race):
    if pd.isna(race):
        return 'UNKNOWN/OTHER'
    
    race = str(race).upper()
    if 'WHITE' in race or 'PORTUGUESE' in race:
        return 'WHITE'
    elif 'BLACK' in race:
        return 'BLACK'
    elif 'ASIAN' in race:
        return 'ASIAN'
    elif 'HISPANIC' in race or 'LATINO' in race or 'SOUTH AMERICAN' in race:
        return 'HISPANIC/LATINO'
    else:
        return 'UNKNOWN/OTHER'


