    if any(w in title for w in ['heart failure', 'chf', 'cardiomyopathy', 'cor pulmonale']): return 'Heart_Failure'
    if any(w in title for w in ['fibrillation', 'arrhythmia', 'tachycardia', 'bradycardia', 'flutter', 'block', 'sick sinus']): return 'Cardiac_Arrhythmia'
    if any(w in title for w in ['valve', 'aortic', 'mitral', 'endocarditis', 'tricuspid']): return 'Valvular_Disease'
    if any(w in title for w in ['aneurysm', 'dissection']): return 'Aortic_Aneurysm_Dissection'
